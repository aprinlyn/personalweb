---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — ApriLiyantoko`} description={post.data.description}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <!-- Back link -->
    <a href="/blog" class="group mb-8 inline-flex items-center gap-1.5 font-mono text-sm text-gray-400 transition-colors hover:text-accent-600 dark:hover:text-accent-400">
      <svg class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      cd ../blog
    </a>

    <!-- Post header -->
    <header class="mb-12">
      <div class="mb-4 flex flex-wrap items-center gap-3">
        <time class="font-mono text-sm text-gray-400 dark:text-gray-500" datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="text-gray-300 dark:text-gray-700">/</span>
        {post.data.tags.map((tag) => (
          <span class="rounded-md border border-gray-200 bg-gray-100 px-2 py-0.5 font-mono text-[11px] text-gray-500 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400">
            #{tag}
          </span>
        ))}
      </div>
      <h1 class="text-3xl font-extrabold leading-tight text-gray-900 dark:text-white md:text-4xl lg:text-5xl">
        {post.data.title}
      </h1>
      <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">{post.data.description}</p>
      <div class="mt-8 h-px bg-gradient-to-r from-primary-600/40 via-accent-500/40 to-transparent"></div>
    </header>

    <!-- Post content -->
    <div class="prose max-w-none text-gray-700 dark:text-gray-300">
      <Content />
    </div>

    <!-- Post footer -->
    <div class="mt-16 rounded-2xl border border-gray-200/60 bg-gray-50 p-8 text-center dark:border-gray-800/60 dark:bg-gray-900/60">
      <p class="mb-2 text-lg font-bold text-gray-900 dark:text-white">Enjoyed this article?</p>
      <p class="mb-4 text-sm text-gray-500 dark:text-gray-400">Follow me for more content on testing, engineering, and building software.</p>
      <div class="flex justify-center gap-3">
        <a href="https://github.com/aprinlyn" target="_blank" rel="noopener" class="rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-600 transition-all hover:border-accent-400/50 hover:text-accent-600 hover:shadow-md dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:border-accent-500/40 dark:hover:text-accent-400">GitHub</a>
        <a href="https://linkedin.com/in/aprinurliyantoko" target="_blank" rel="noopener" class="rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-600 transition-all hover:border-accent-400/50 hover:text-accent-600 hover:shadow-md dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:border-accent-500/40 dark:hover:text-accent-400">LinkedIn</a>
        <a href="/rss.xml" class="rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-600 transition-all hover:border-accent-400/50 hover:text-accent-600 hover:shadow-md dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:border-accent-500/40 dark:hover:text-accent-400">RSS</a>
      </div>
    </div>
  </article>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

const projects = [
  {
    title: 'Portfolio Website',
    description: 'This site — built with Astro and Tailwind CSS. Dark mode, interactive playground, and a Markdown blog.',
    tech: ['Astro', 'Tailwind CSS', 'TypeScript', 'React'],
    github: 'https://github.com/aprinlyn/personalweb',
    demo: '/',
    status: 'Live',
  },
  {
    title: 'Automation API Generator',
    description: 'An LLM-driven tool that automates code generation for new changes',
    tech: ['Python', 'AI Agent', 'Serenity BDD Framework', 'Swagger'],
    github: 'https://github.com/yourusername/api-health-dashboard',
    demo: null,
    status: 'In Progress',
  },
  {
    title: 'Test Automation Showcase',
    description: 'Comprehensive test suite demonstrating E2E, integration, and API testing patterns with Playwright.',
    tech: ['Playwright', 'TypeScript', 'GitHub Actions', 'Docker'],
    github: 'https://github.com/yourusername/test-automation-showcase',
    demo: null,
    status: 'In Progress',
  },
  {
    title: 'Flaky Test Detector',
    description: 'CLI tool that analyzes test run history to identify flaky tests and generate actionable reports.',
    tech: ['Python', 'Click', 'SQLite', 'Rich'],
    github: 'https://github.com/yourusername/flaky-test-detector',
    demo: null,
    status: 'Planned',
  },
  {
    title: 'Bug Bash Tracker',
    description: 'Lightweight web app for tracking bugs during exploratory testing sessions.',
    tech: ['React', 'TypeScript', 'Tailwind CSS', 'LocalStorage'],
    github: 'https://github.com/yourusername/bug-bash-tracker',
    demo: null,
    status: 'Planned',
  },
];

const statusConfig: Record<string, { dot: string; bg: string; text: string }> = {
  'Live': { dot: 'bg-accent-500', bg: 'bg-accent-500/10', text: 'text-accent-600 dark:text-accent-400' },
  'In Progress': { dot: 'bg-yellow-500', bg: 'bg-yellow-500/10', text: 'text-yellow-600 dark:text-yellow-400' },
  'Planned': { dot: 'bg-gray-400', bg: 'bg-gray-400/10', text: 'text-gray-500 dark:text-gray-400' },
};
---

<BaseLayout title="Blog & Projects — Apri's" description="Articles, writings, and project showcases.">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-gray-200/50 dark:border-gray-800/50">
    <div class="pointer-events-none absolute inset-0">
      <div class="animate-blob absolute right-10 top-0 h-60 w-60 rounded-full bg-primary-300/10 blur-3xl dark:bg-primary-600/5"></div>
    </div>
    <div class="relative mx-auto max-w-5xl px-6 py-20">
      <p class="mb-4 font-mono text-sm text-accent-600 dark:text-accent-400">~/blog</p>
      <h1 class="mb-4 text-4xl font-extrabold text-gray-900 dark:text-white md:text-5xl">
        Projects & <span class="gradient-text">Writings</span>
      </h1>
      <p class="max-w-xl text-lg text-gray-500 dark:text-gray-400">
        Things I've built, and thoughts I've written down.
      </p>
    </div>
  </section>

  <!-- Projects section -->
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="mb-8 flex items-center gap-3">
      <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
      <h2 class="font-mono text-xs uppercase tracking-widest text-gray-400 dark:text-gray-500">Projects</h2>
      <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project, i) => (
        <div class="group flex flex-col overflow-hidden rounded-2xl border border-gray-200/60 bg-white/80 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60">
          <div class="h-0.5 bg-gradient-to-r from-primary-600 to-accent-500 opacity-50"></div>
          <div class="flex flex-1 flex-col p-5">
            <div class="mb-3 flex items-center justify-between">
              <span class="font-mono text-xs text-gray-400 dark:text-gray-600">{String(i + 1).padStart(2, '0')}</span>
              <div class={`flex items-center gap-1.5 rounded-full ${statusConfig[project.status].bg} px-2 py-0.5`}>
                <span class={`h-1.5 w-1.5 rounded-full ${statusConfig[project.status].dot} ${project.status === 'Live' ? 'animate-pulse' : ''}`}></span>
                <span class={`text-[10px] font-medium ${statusConfig[project.status].text}`}>{project.status}</span>
              </div>
            </div>
            <h3 class="mb-2 font-bold text-gray-900 dark:text-white">{project.title}</h3>
            <p class="mb-4 flex-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">{project.description}</p>
            <div class="mb-4 flex flex-wrap gap-1">
              {project.tech.map((t) => (
                <span class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-[10px] text-gray-500 dark:bg-gray-800 dark:text-gray-400">{t}</span>
              ))}
            </div>
            <div class="flex items-center gap-3 border-t border-gray-100 pt-3 dark:border-gray-800">
              <a href={project.github} target="_blank" rel="noopener" class="link-underline text-xs font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
                Source
              </a>
              {project.demo && (
                <a href={project.demo} class="text-xs font-medium text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300">
                  Live Demo
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Blog posts section -->
  <section class="mx-auto max-w-5xl px-6 pb-20">
    <div class="mb-8 flex items-center gap-3">
      <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
      <h2 class="font-mono text-xs uppercase tracking-widest text-gray-400 dark:text-gray-500">Articles</h2>
      <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
    </div>

    {posts.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-gray-300 p-12 text-center dark:border-gray-700">
        <p class="font-mono text-gray-400 dark:text-gray-500">No posts yet. Check back soon!</p>
      </div>
    ) : (
      <div class="space-y-6">
        {/* Featured post */}
        {featured && (
          <a href={`/blog/${featured.id}`} class="group block overflow-hidden rounded-2xl border border-gray-200/60 bg-white/80 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60">
            <div class="p-8">
              <div class="mb-4 flex items-center gap-3">
                <span class="rounded-full bg-accent-500/10 px-3 py-1 text-xs font-bold text-accent-600 dark:text-accent-400">Latest</span>
                <time class="font-mono text-xs text-gray-400 dark:text-gray-500" datetime={featured.data.pubDate.toISOString()}>
                  {featured.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <h3 class="mb-3 text-xl font-bold text-gray-900 transition-colors group-hover:text-accent-600 dark:text-white dark:group-hover:text-accent-400 md:text-2xl">
                {featured.data.title}
              </h3>
              <p class="mb-4 text-gray-500 dark:text-gray-400">{featured.data.description}</p>
              <div class="flex flex-wrap gap-2">
                {featured.data.tags.map((tag) => (
                  <span class="rounded-md border border-gray-200 bg-gray-50 px-2 py-0.5 font-mono text-[11px] text-gray-500 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400">
                    #{tag}
                  </span>
                ))}
              </div>
              <div class="mt-5 inline-flex items-center gap-1 font-mono text-sm text-accent-600 dark:text-accent-400">
                read article <span class="transition-transform group-hover:translate-x-2">&rarr;</span>
              </div>
            </div>
          </a>
        )}

        {rest.length > 0 && (
          <div class="space-y-3">
            {rest.map((post) => (
              <a href={`/blog/${post.id}`} class="group flex items-start gap-5 rounded-xl border border-gray-200/60 bg-white/80 p-5 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gray-100 text-center font-mono text-xs font-bold leading-tight text-gray-400 dark:bg-gray-800 dark:text-gray-500">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short' }).toUpperCase()}<br />
                  {post.data.pubDate.getDate()}
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="mb-1 font-semibold text-gray-900 transition-colors group-hover:text-accent-600 dark:text-white dark:group-hover:text-accent-400">
                    {post.data.title}
                  </h3>
                  <p class="mb-2 text-sm text-gray-500 dark:text-gray-400 line-clamp-1">{post.data.description}</p>
                  <div class="flex gap-1.5">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-[10px] text-gray-500 dark:bg-gray-800 dark:text-gray-500">#{tag}</span>
                    ))}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    )}
  </section>
</BaseLayout>

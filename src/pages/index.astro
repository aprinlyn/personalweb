---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Apri's Portfolio">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Muted blobs -->
    <div class="pointer-events-none absolute inset-0">
      <div class="animate-blob absolute -left-20 top-10 h-72 w-72 rounded-full bg-primary-400/10 blur-3xl dark:bg-primary-600/5"></div>
      <div class="animate-blob-delay-2 absolute right-10 top-40 h-72 w-72 rounded-full bg-accent-500/10 blur-3xl dark:bg-accent-500/5"></div>
      <div class="animate-blob-delay-4 absolute -bottom-20 left-1/3 h-72 w-72 rounded-full bg-primary-300/10 blur-3xl dark:bg-primary-700/5"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-6 py-24 md:py-36">
      <div class="flex flex-col items-center text-center">
        <!-- Status badge -->
        <div class="animate-slide-up mb-8 inline-flex items-center gap-2 rounded-full border border-gray-200/50 bg-white/60 px-4 py-1.5 text-sm backdrop-blur-sm dark:border-gray-700/50 dark:bg-gray-800/40">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-500 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-500"></span>
          </span>
          <span class="text-gray-600 dark:text-gray-300">hello!!</span>
        </div>

        <!-- Heading -->
        <h1 class="animate-slide-up-delay-1 mb-6 text-5xl font-extrabold leading-[1.1] tracking-tight text-gray-900 dark:text-white md:text-7xl">
          I build things that<br />
          <span class="gradient-text">don't break</span>
        </h1>

        <!-- Code-style sub -->
        <div class="animate-slide-up-delay-2 mb-4 font-mono text-sm text-gray-400 dark:text-gray-500 md:text-base">
          <span class="text-accent-600 dark:text-accent-400">const</span> role = <span class="text-primary-600 dark:text-primary-300">"Software Development Engineer In Test"</span>;
        </div>

        <p class="animate-slide-up-delay-2 mx-auto mb-10 max-w-xl text-lg leading-relaxed text-gray-500 dark:text-gray-400">
          Crafting reliable software and thorough test strategies. Passionate about quality engineering, automation, and tools that make developers' lives easier.
        </p>

        <!-- CTA -->
        <div class="animate-slide-up-delay-3 flex flex-wrap justify-center gap-4">
          <a href="/projects" class="group inline-flex items-center gap-2 rounded-xl bg-primary-800 px-7 py-3.5 font-medium text-white shadow-lg shadow-primary-900/20 transition-all hover:bg-primary-700 hover:shadow-xl dark:bg-primary-700 dark:hover:bg-primary-600">
            <span>View My Work</span>
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/contact" class="group inline-flex items-center gap-2 rounded-xl border border-gray-300 bg-white/80 px-7 py-3.5 font-medium text-gray-700 backdrop-blur-sm transition-all hover:border-gray-400 hover:shadow-md dark:border-gray-700 dark:bg-gray-800/80 dark:text-gray-200 dark:hover:border-gray-600">
            Get in Touch
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-500/20 to-transparent"></div>
  </section>

  <!-- Bento Grid -->
  <section class="relative mx-auto max-w-6xl px-8 py-24">
    <div class="mb-12 text-center">
      <h2 class="mb-2 font-mono text-sm uppercase tracking-widest text-accent-600 dark:text-accent-400">Explore</h2>
      <p class="text-3xl font-bold text-gray-900 dark:text-white">What I've been up to</p>
    </div>

    <div class="grid gap-4 md:grid-cols-6 md:grid-rows-1">
      <!-- Projects — large card -->
      <a href="/projects" class="group relative col-span-full overflow-hidden rounded-2xl border border-gray-200/60 bg-white/80 p-8 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60 md:col-span-3">
        <div class="absolute -right-8 -top-8 h-40 w-40 rounded-full bg-primary-400/5 blur-2xl transition-all group-hover:bg-primary-400/10 dark:bg-primary-500/5"></div>
        <div class="relative">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary-800 text-white shadow-md dark:bg-primary-700">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Blog & Projects</h3>
          <p class="max-w-md text-gray-500 dark:text-gray-400">Portfolio of applications, engineering write-ups, and developer tools I've built.</p>
          <div class="mt-4 inline-flex items-center gap-1 font-mono text-sm text-accent-600 dark:text-accent-400">
            explore <span class="transition-transform group-hover:translate-x-2">&rarr;</span>
          </div>
        </div>
      </a>

      <!-- Stats -->
      <!-- <div class="col-span-full flex flex-col items-center justify-center rounded-2xl border border-gray-200/60 bg-white/80 p-6 backdrop-blur-sm dark:border-gray-800/60 dark:bg-gray-900/60 md:col-span-2">
        <div class="text-5xl font-extrabold text-primary-800 dark:text-primary-300">5+</div>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Projects & Counting</p>
      </div> -->

      <!-- Blog + Projects -->
      <!-- <a href="/blog" class="group relative col-span-full overflow-hidden rounded-2xl border border-gray-200/60 bg-white/80 p-8 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60 md:col-span-3">
        <div class="absolute -bottom-8 -right-8 h-40 w-40 rounded-full bg-primary-300/5 blur-2xl transition-all group-hover:bg-primary-300/10 dark:bg-primary-700/5"></div>
        <div class="relative">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary-700 text-white shadow-md dark:bg-primary-600">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Blog & Projects</h3>
          <p class="text-gray-500 dark:text-gray-400">Articles, project showcases, and engineering write-ups.</p>
          <div class="mt-4 inline-flex items-center gap-1 font-mono text-sm text-accent-600 dark:text-accent-400">
            explore <span class="transition-transform group-hover:translate-x-2">&rarr;</span>
          </div>
        </div>
      </a> -->

      <!-- Playground -->
      <a href="/playground" class="group relative col-span-full overflow-hidden rounded-2xl border border-gray-200/60 bg-white/80 p-8 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60 md:col-span-3">
        <div class="absolute -bottom-8 -left-8 h-40 w-40 rounded-full bg-accent-500/5 blur-2xl transition-all group-hover:bg-accent-500/10"></div>
        <div class="relative">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-accent-600 text-white shadow-md dark:bg-accent-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Playground</h3>
          <p class="text-gray-500 dark:text-gray-400">Interactive tools and experiments — JSON formatters, regex testers, and more.</p>
          <div class="mt-4 inline-flex items-center gap-1 font-mono text-sm text-accent-600 dark:text-accent-400">
            try it <span class="transition-transform group-hover:translate-x-2">&rarr;</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Terminal "Currently Working On" -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 dot-grid opacity-50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-gray-50 via-transparent to-gray-50 dark:from-gray-950 dark:via-transparent dark:to-gray-950"></div>

    <div class="relative mx-auto max-w-3xl px-6 py-24">
      <div class="mb-8 text-center">
        <h2 class="mb-2 font-mono text-sm uppercase tracking-widest text-accent-600 dark:text-accent-400">Status</h2>
        <p class="text-3xl font-bold text-gray-900 dark:text-white">Currently Working On</p>
      </div>

      <!-- Terminal -->
      <div class="overflow-hidden rounded-2xl border border-gray-800/80 bg-[#102a43] shadow-2xl dark:border-gray-700/50">
        <div class="flex items-center gap-2 border-b border-gray-700/50 px-4 py-3">
          <div class="h-3 w-3 rounded-full bg-gray-600/60"></div>
          <div class="h-3 w-3 rounded-full bg-gray-600/60"></div>
          <div class="h-3 w-3 rounded-full bg-gray-600/60"></div>
          <span class="ml-2 font-mono text-xs text-gray-500">~/projects/status</span>
        </div>
        <div class="p-6 font-mono text-sm leading-relaxed">
          <div class="mb-4">
            <span class="text-accent-400">$</span>
            <span class="text-gray-300"> cat current_projects.json</span>
          </div>
          <div class="space-y-3 pl-2">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded bg-accent-500/15 text-xs text-accent-400">&#10003;</span>
              <div>
                <span class="text-gray-200">Building this portfolio website</span>
                <div class="mt-0.5 text-xs text-gray-500">Astro + Tailwind CSS + React islands</div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded bg-yellow-500/15 text-xs text-yellow-500">&#8943;</span>
              <div>
                <span class="text-gray-500">Test Automation Showcase</span>
                <div class="mt-0.5 text-xs text-gray-500">LLM + Serenity BDD + GitHub Actions CI/CD</div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded bg-primary-500/15 text-xs text-primary-300">&#9679;</span>
              <div>
                <span class="text-gray-500">API Health Dashboard</span>
                <div class="mt-0.5 text-xs text-gray-500">React + real-time monitoring</div>
              </div>
            </div>
          </div>
          <div class="mt-6 flex items-center gap-1">
            <span class="text-accent-400">$</span>
            <span class="animate-pulse text-gray-500">_</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="border-t border-gray-200/50 dark:border-gray-800/50">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <p class="mb-8 text-center font-mono text-xs uppercase tracking-widest text-gray-400 dark:text-gray-500">Tech I work with</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {['Java', 'Python', 'Springboot', 'React', 'Cucumber', 'Selenium', 'Git', 'BDD', 'Jenkins', 'PostgreSQL', 'Mongo', 'Jmeter'].map((tech) => (
          <span class="rounded-lg border border-gray-200 bg-white px-4 py-2 font-mono text-xs font-medium text-gray-500 transition-all hover:border-accent-400/40 hover:text-accent-600 dark:border-gray-800 dark:bg-gray-900 dark:text-gray-400 dark:hover:border-accent-500/30 dark:hover:text-accent-400">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

                placeholder="What's on your mind?"></textarea>
            </div>
            <button type="submit"
              class="group w-full rounded-xl bg-primary-800 px-6 py-3.5 font-medium text-white shadow-md transition-all hover:bg-primary-700 hover:shadow-lg dark:bg-primary-700 dark:hover:bg-primary-600">
              <span class="flex items-center justify-center gap-2">
                Send Message
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </button>
          </form>

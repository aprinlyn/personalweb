---
import BaseLayout from '../layouts/BaseLayout.astro';

const skillCategories = [
  {
    title: 'Languages',
    skills: ['Java', 'Python', 'Javascript', 'No SQL', 'SQL'],
  },
  {
    title: 'Testing & QA',
    skills: ['Cucumber', 'BDD', 'Selenium', 'Jmeter', 'K6', 'Postman'],
  },
  {
    title: 'Frameworks',
    skills: ['Springboot', 'Serenity BDD', 'TestNG','Tailwind CSS', ],
  },
  {
    title: 'CI/CD & DevOps',
    skills: ['GitHub Actions', 'Jenkins', 'Docker', 'Git', 'Linux'],
  },
];
---

<BaseLayout title="Contact — Apri" description="About me, my skills, and how to get in touch.">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-gray-200/50 dark:border-gray-800/50">
    <div class="pointer-events-none absolute inset-0">
      <div class="animate-blob absolute -right-10 top-0 h-60 w-60 rounded-full bg-accent-500/10 blur-3xl dark:bg-accent-500/5"></div>
      <div class="animate-blob-delay-4 absolute -left-10 bottom-0 h-60 w-60 rounded-full bg-primary-300/10 blur-3xl dark:bg-primary-600/5"></div>
    </div>
    <div class="relative mx-auto max-w-5xl px-6 py-20">
      <p class="mb-4 font-mono text-sm text-accent-600 dark:text-accent-400">~/contact</p>
      <h1 class="mb-4 text-4xl font-extrabold text-gray-900 dark:text-white md:text-5xl">
        About & <span class="gradient-text">Contact</span>
      </h1>
      <p class="max-w-xl text-lg text-gray-500 dark:text-gray-400">
        A bit about who I am, and how to reach me.
      </p>
    </div>
  </section>

  <!-- Bio -->
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="mb-8 flex items-center gap-3">
      <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
      <h2 class="font-mono text-xs uppercase tracking-widest text-gray-400 dark:text-gray-500">About</h2>
      <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
    </div>

    <div class="grid items-start gap-12 md:grid-cols-5">
      <!-- Avatar -->
      <div class="flex justify-center md:col-span-2">
        <div class="relative">
          <div class="h-44 w-44 overflow-hidden rounded-2xl border-2 border-primary-200 dark:border-primary-800">
            <div class="flex h-full w-full items-center justify-center bg-primary-50 dark:bg-primary-900/30">                  
                   <span class="text-5xl font-bold text-primary-800 dark:text-primary-300">&lt;/&gt;</span> 
            </div>
          </div>
          <!-- <div class="animate-float absolute -bottom-3 -right-3 rounded-lg bg-accent-600 px-3 py-1.5 text-xs font-bold text-white shadow-md dark:bg-accent-500">
            Open to work
          </div> -->
        </div>
      </div>

      <!-- Bio text -->
      <div class="space-y-4 text-base leading-relaxed text-gray-600 dark:text-gray-400 md:col-span-3">
        <p>
          I'm an Software Engineer with a passion for building reliable, well-tested software. Quality isn't just a phase — it's a mindset embedded in every line of code.
        </p>
        <p>
          My journey started with a curiosity for how things work <em>(and how they break)</em>. That led me to specialize in test automation, quality engineering, and building tools that help teams ship with confidence.
        </p>
        <p>
          I also enjoy exploring new technologies, AI, and continuously improving my engineering practices to build better software.
        </p>
        <div class="hidden pt-2">
          <a href="/resume.pdf" class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition-all hover:border-accent-400/50 hover:shadow-md dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200 dark:hover:border-accent-500/40">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Resume
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 dot-grid opacity-40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-gray-50/80 via-transparent to-gray-50/80 dark:from-gray-950/80 dark:via-transparent dark:to-gray-950/80"></div>

    <div class="relative mx-auto max-w-5xl px-6 py-16">
      <div class="mb-8 flex items-center gap-3">
        <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
        <h2 class="font-mono text-xs uppercase tracking-widest text-gray-400 dark:text-gray-500">Skills</h2>
        <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
      </div>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {skillCategories.map((category) => (
          <div class="rounded-2xl border border-gray-200/60 bg-white/80 p-5 backdrop-blur-sm dark:border-gray-800/60 dark:bg-gray-900/60">
            <h3 class="mb-3 font-mono text-xs font-semibold uppercase tracking-wider text-accent-600 dark:text-accent-400">{category.title}</h3>
            <div class="flex flex-wrap gap-1.5">
              {category.skills.map((skill) => (
                <span class="rounded-md border border-gray-200 bg-gray-50 px-2 py-0.5 text-xs text-gray-600 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="mb-8 flex items-center gap-3">
      <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
      <h2 class="font-mono text-xs uppercase tracking-widest text-gray-400 dark:text-gray-500">Get in Touch</h2>
      <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
    </div>

    <div class="grid gap-10 md:grid-cols-5">
      <!-- Links -->
      <div class="space-y-3 md:col-span-2">
        <p class="mb-5 text-sm text-gray-500 dark:text-gray-400">
          Have a question, want to collaborate, or just say hello?
        </p>

        <a href="mailto:your@email.com" class="group flex items-center gap-4 rounded-2xl border border-gray-200/60 bg-white/80 p-4 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary-800 text-white shadow-md transition-transform group-hover:scale-105 dark:bg-primary-700">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-white">Email</p>
            <p class="font-mono text-xs text-gray-500 dark:text-gray-400">liyantoko.apri@gmail.com</p>
          </div>
        </a>

        <a href="https://github.com/aprinlyn" target="_blank" rel="noopener" class="group flex items-center gap-4 rounded-2xl border border-gray-200/60 bg-white/80 p-4 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gray-800 text-white shadow-md transition-transform group-hover:scale-105 dark:bg-gray-700">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-white">GitHub</p>
            <p class="font-mono text-xs text-gray-500 dark:text-gray-400">github.com/aprinlyn</p>
          </div>
        </a>

        <a href="https://linkedin.com/in/aprinurliyantoko" target="_blank" rel="noopener" class="group flex items-center gap-4 rounded-2xl border border-gray-200/60 bg-white/80 p-4 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary-700 text-white shadow-md transition-transform group-hover:scale-105 dark:bg-primary-600">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-white">LinkedIn</p>
            <p class="font-mono text-xs text-gray-500 dark:text-gray-400">linkedin.com/in/aprinurliyantoko</p>
          </div>
        </a>
      </div>

      <!-- Form -->
      <!-- <div class="md:col-span-3">
        <div class="overflow-hidden rounded-2xl border border-gray-200/60 bg-white/80 backdrop-blur-sm dark:border-gray-800/60 dark:bg-gray-900/60">
          <div class="border-b border-gray-200/60 bg-gray-50/80 px-6 py-3 dark:border-gray-800/60 dark:bg-gray-800/60">
            <div class="flex items-center gap-2">
              <div class="h-2.5 w-2.5 rounded-full bg-gray-300 dark:bg-gray-600"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-gray-300 dark:bg-gray-600"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-gray-300 dark:bg-gray-600"></div>
              <span class="ml-2 font-mono text-xs text-gray-400 dark:text-gray-500">new_message.md</span>

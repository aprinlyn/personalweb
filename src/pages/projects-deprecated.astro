---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Portfolio Website',
    description: 'This very site — a clean, fast portfolio built with Astro and Tailwind CSS. Features dark mode, interactive playground tools, and a blog powered by Markdown.',
    tech: ['Astro', 'Tailwind CSS', 'TypeScript', 'React'],
    github: 'https://github.com/yourusername/portfolio-website',
    demo: '/',
    status: 'Live',
  },
  {
    title: 'Automation API Generator',
    description: 'A monitoring dashboard that pings public APIs and displays their health status in real-time with charts and alerts.',
    tech: ['React', 'Node.js', 'REST APIs', 'Chart.js'],
    github: 'https://github.com/yourusername/api-health-dashboard',
    demo: null,
    status: 'In Progress',
  },
  {
    title: 'Test Automation Showcase',
    description: 'An LLM-driven tool that automates code generation for new changes.',
    tech: ['Python', 'AI Agent', 'Serenity BDD Framework', 'Swagger',],
    github: 'https://github.com/yourusername/test-automation-showcase',
    demo: null,
    status: 'In Progress',
  },
  {
    title: 'Flaky Test Detector',
    description: 'CLI tool that analyzes test run history to identify flaky tests, track failure patterns, and generate actionable reports.',
    tech: ['Python', 'Click', 'SQLite', 'Rich'],
    github: 'https://github.com/yourusername/flaky-test-detector',
    demo: null,
    status: 'Planned',
  },
  {
    title: 'Bug Bash Tracker',
    description: 'Lightweight web app for tracking bugs during exploratory testing sessions. Categorize, prioritize, and export findings.',
    tech: ['React', 'TypeScript', 'Tailwind CSS', 'LocalStorage'],
    github: 'https://github.com/yourusername/bug-bash-tracker',
    demo: null,
    status: 'Planned',
  },
];

const statusConfig: Record<string, { dot: string; bg: string; text: string }> = {
  'Live': { dot: 'bg-accent-500', bg: 'bg-accent-500/10', text: 'text-accent-600 dark:text-accent-400' },
  'In Progress': { dot: 'bg-yellow-500', bg: 'bg-yellow-500/10', text: 'text-yellow-600 dark:text-yellow-400' },
  'Planned': { dot: 'bg-gray-400', bg: 'bg-gray-400/10', text: 'text-gray-500 dark:text-gray-400' },
};
---

<BaseLayout title="Projects — ApriLiyantoko" description="Explore my portfolio of applications, test automation showcases, and developer tools.">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-gray-200/50 dark:border-gray-800/50">
    <div class="pointer-events-none absolute inset-0">
      <div class="animate-blob absolute -right-20 top-0 h-60 w-60 rounded-full bg-accent-500/10 blur-3xl dark:bg-accent-500/5"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6 py-20">
      <p class="mb-4 font-mono text-sm text-accent-600 dark:text-accent-400">~/projects</p>
      <h1 class="mb-4 text-4xl font-extrabold text-gray-900 dark:text-white md:text-5xl">
        Things I've <span class="gradient-text">built</span>
      </h1>
      <p class="max-w-xl text-lg text-gray-500 dark:text-gray-400">
        A collection of projects showcasing software engineering, test automation, and developer tooling.
      </p>
    </div>
  </section>

  <!-- Grid -->
  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((project, i) => (
        <div class="group relative overflow-hidden rounded-2xl border border-gray-200/60 bg-white/80 backdrop-blur-sm transition-all hover-lift dark:border-gray-800/60 dark:bg-gray-900/60">
          <!-- Top accent line -->
          <div class="h-0.5 bg-gradient-to-r from-primary-600 to-accent-500 opacity-60"></div>

          <div class="p-6">
            <div class="mb-4 flex items-start justify-between">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary-800 font-mono text-sm font-bold text-white shadow-md dark:bg-primary-700">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">{project.title}</h3>
              </div>
              <div class={`flex items-center gap-1.5 rounded-full ${statusConfig[project.status].bg} px-2.5 py-1`}>
                <span class={`h-1.5 w-1.5 rounded-full ${statusConfig[project.status].dot} ${project.status === 'Live' ? 'animate-pulse' : ''}`}></span>
                <span class={`text-xs font-medium ${statusConfig[project.status].text}`}>{project.status}</span>
              </div>
            </div>

            <p class="mb-5 text-sm leading-relaxed text-gray-500 dark:text-gray-400">{project.description}</p>

            <div class="mb-5 flex flex-wrap gap-1.5">
              {project.tech.map((t) => (
                <span class="rounded-md border border-gray-200 bg-gray-50 px-2 py-0.5 font-mono text-[11px] text-gray-500 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400">
                  {t}
                </span>
              ))}
            </div>

            <div class="flex items-center gap-4 border-t border-gray-100 pt-4 dark:border-gray-800">
              <a href={project.github} target="_blank" rel="noopener" class="link-underline inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                Source
              </a>
              {project.demo && (
                <a href={project.demo} class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  Live Demo
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

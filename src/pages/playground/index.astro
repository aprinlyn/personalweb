---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  {
    title: 'JSON Formatter / Validator',
    description: 'Paste JSON, get it pretty-printed and validated instantly. Highlights errors with descriptive messages.',
    href: '/playground/json-formatter',
    icon: '{ }',
    available: true,
  },
  {
    title: 'Regex Tester',
    description: 'Test regex patterns against strings with real-time match highlighting and group extraction.',
    href: '/playground/regex-tester',
    icon: '/.*/',
    available: false,
  },
  {
    title: 'HTTP Status Codes',
    description: 'Searchable, filterable reference of all HTTP status codes with descriptions and use cases.',
    href: '/playground/http-status',
    icon: '200',
    available: false,
  },
  {
    title: 'API Request Builder',
    description: 'Build and send HTTP requests with a visual form. Set headers, body, and see responses.',
    href: '/playground/api-builder',
    icon: 'GET',
    available: false,
  },
];
---

<BaseLayout title="Playground — ApriLiyantoko" description="Interactive developer tools and experiments.">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-gray-200/50 dark:border-gray-800/50">
    <div class="pointer-events-none absolute inset-0">
      <div class="animate-blob absolute -left-10 top-0 h-60 w-60 rounded-full bg-primary-300/10 blur-3xl dark:bg-primary-600/5"></div>
      <div class="animate-blob-delay-4 absolute -right-10 bottom-0 h-60 w-60 rounded-full bg-accent-500/10 blur-3xl dark:bg-accent-500/5"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6 py-20">
      <p class="mb-4 font-mono text-sm text-accent-600 dark:text-accent-400">~/playground</p>
      <h1 class="mb-4 text-4xl font-extrabold text-gray-900 dark:text-white md:text-5xl">
        <span class="gradient-text">Interactive</span> tools
      </h1>
      <p class="max-w-xl text-lg text-gray-500 dark:text-gray-400">
        Built for fun, useful for real work. Each tool is a self-contained experiment.
      </p>
    </div>
  </section>

  <!-- Tools grid -->
  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <div class:list={[
          'group relative overflow-hidden rounded-2xl border transition-all',
          tool.available
            ? 'border-gray-200/60 bg-white/80 backdrop-blur-sm hover-lift dark:border-gray-800/60 dark:bg-gray-900/60'
            : 'border-dashed border-gray-300/50 bg-gray-50/50 dark:border-gray-700/50 dark:bg-gray-900/30',
        ]}>
          {tool.available && <div class="h-0.5 bg-gradient-to-r from-primary-600 to-accent-500 opacity-60"></div>}

          <div class="p-6">
            <div class="mb-4 flex items-center gap-3">
              <div class:list={[
                'flex h-11 w-11 items-center justify-center rounded-xl font-mono text-sm font-bold text-white shadow-md',
                tool.available
                  ? 'bg-primary-800 dark:bg-primary-700'
                  : 'bg-gray-300 dark:bg-gray-700',
              ]}>
                {tool.icon}
              </div>
              <div>
                <h3 class:list={[
                  'font-bold',
                  tool.available
                    ? 'text-gray-900 dark:text-white'
                    : 'text-gray-400 dark:text-gray-500',
                ]}>{tool.title}</h3>
                {!tool.available && (
                  <span class="font-mono text-[10px] uppercase tracking-wider text-gray-400 dark:text-gray-500">coming soon</span>
                )}
              </div>
            </div>

            <p class:list={[
              'mb-5 text-sm leading-relaxed',
              tool.available ? 'text-gray-500 dark:text-gray-400' : 'text-gray-400 dark:text-gray-600',
            ]}>{tool.description}</p>

            {tool.available ? (
              <a href={tool.href} class="group/link inline-flex items-center gap-2 rounded-xl bg-primary-800 px-5 py-2.5 text-sm font-medium text-white shadow-md transition-all hover:bg-primary-700 dark:bg-primary-700 dark:hover:bg-primary-600">
                Open Tool
                <svg class="h-4 w-4 transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            ) : (
              <div class="inline-flex items-center gap-2 rounded-xl border border-dashed border-gray-300 px-5 py-2.5 text-sm text-gray-400 dark:border-gray-700 dark:text-gray-500">
                <span class="h-1.5 w-1.5 rounded-full bg-gray-300 dark:bg-gray-600"></span>
                In the workshop
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

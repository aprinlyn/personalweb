---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonFormatter from '../../components/JsonFormatter';
---

<BaseLayout title="JSON Formatter — Playground — ApriLiyantoko" description="Paste JSON, get it pretty-printed and validated instantly.">
  <section class="mx-auto max-w-6xl px-6 py-12">
    <div class="mb-8">
      <a href="/playground" class="group mb-4 inline-flex items-center gap-1.5 font-mono text-sm text-gray-400 transition-colors hover:text-primary-500">
        <svg class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        cd ../playground
      </a>
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-blue-500 to-cyan-500 font-mono text-sm font-bold text-white shadow-lg shadow-blue-500/20">
          { }
        </div>
        <div>
          <h1 class="text-2xl font-extrabold text-gray-900 dark:text-white">JSON Formatter / Validator</h1>
          <p class="text-sm text-gray-500 dark:text-gray-400">Format, validate, or minify JSON with descriptive error messages.</p>
        </div>
      </div>
    </div>

    <JsonFormatter client:load />
  </section>
</BaseLayout>

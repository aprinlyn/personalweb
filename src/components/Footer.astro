---
const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: 'GitHub',
    href: 'https://github.com/aprinlyn',
    svg: '<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>',
    fill: true,
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com/in/aprinurliyantoko/',
    svg: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>',
    fill: true,
  },
  {
    name: 'Email',
    href: 'mailto:liyantoko.apri@gmail.com',
    svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>',
    fill: false,
  },
];
---

<footer class="relative border-t border-gray-200/60 dark:border-gray-800/60">
  <!-- Subtle top line -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-500/30 to-transparent"></div>

  <div class="relative mx-auto max-w-6xl px-6 pb-8 pt-16">
    <div class="grid gap-12 md:grid-cols-12">
      <!-- Brand -->
      <div class="md:col-span-5">
        <a href="/" class="group inline-flex items-center gap-2">
          <img src="/logos.svg" alt="Logo" class="h-9 w-9 object-contain" />
          <span class="text-lg font-bold tracking-tight text-gray-900 dark:text-gray-100">
            Apri<span class="text-accent-500">Liyantoko</span>
          </span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-gray-500 dark:text-gray-400">
          Software Engineer. Building reliable software and breaking things that need testing.
        </p>
        <div class="mt-6 flex gap-3">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('mailto') ? undefined : '_blank'}
              rel={link.href.startsWith('mailto') ? undefined : 'noopener'}
              aria-label={link.name}
              class="flex h-10 w-10 items-center justify-center rounded-xl border border-gray-200 text-gray-400 transition-all hover:-translate-y-1 hover:border-accent-400/50 hover:text-accent-600 hover:shadow-md dark:border-gray-800 dark:hover:border-accent-500/30 dark:hover:text-accent-400"
            >
              <svg class="h-4 w-4" fill={link.fill ? 'currentColor' : 'none'} stroke={link.fill ? 'none' : 'currentColor'} stroke-width={link.fill ? '0' : '2'} viewBox="0 0 24 24" set:html={link.svg} />
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div class="md:col-span-3">
        <h4 class="mb-4 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">Navigate</h4>
        <ul class="space-y-2.5">
          <li><a href="/blog" class="link-underline text-sm text-gray-600 dark:text-gray-400">Blog & Projects</a></li>
          <li><a href="/playground" class="link-underline text-sm text-gray-600 dark:text-gray-400">Playground</a></li>
          <li><a href="/contact" class="link-underline text-sm text-gray-600 dark:text-gray-400">Contact</a></li>
        </ul>
      </div>

      <!-- Misc -->
      <div class="md:col-span-4">
        <h4 class="mb-4 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">Elsewhere</h4>
        <ul class="space-y-2.5">
          <li><a href="/rss.xml" class="link-underline text-sm text-gray-600 dark:text-gray-400">RSS Feed</a></li>
          <li><a href="/sitemap-index.xml" class="link-underline text-sm text-gray-600 dark:text-gray-400">Sitemap</a></li>
          <li><a href="https://github.com/aprinlyn" target="_blank" rel="noopener" class="link-underline text-sm text-gray-600 dark:text-gray-400">Source Code</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-gray-200/50 pt-8 dark:border-gray-800/50 sm:flex-row">
      <p class="text-xs text-gray-400 dark:text-gray-500">
        &copy; {currentYear} ApriLiyantoko. Crafted with care.
      </p>
      <p class="flex items-center gap-1.5 text-xs text-gray-400 dark:text-gray-500">
        Built with
        <span class="rounded-md bg-gray-100 px-1.5 py-0.5 font-mono text-[10px] font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Astro</span>
        +
        <span class="rounded-md bg-gray-100 px-1.5 py-0.5 font-mono text-[10px] font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Tailwind</span>
      </p>
    </div>
  </div>
</footer>

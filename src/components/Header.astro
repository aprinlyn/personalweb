---
const navLinks = [
  { href: '/', label: 'Home', icon: '~' },
  { href: '/blog', label: 'Blog', icon: '#' },
  { href: '/playground', label: 'Playground', icon: '>' },
  { href: '/contact', label: 'Contact', icon: '&' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-gray-200/60 bg-white/70 backdrop-blur-xl dark:border-gray-800/60 dark:bg-gray-950/70">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2">
      <img src="/logos.svg" alt="Logo" class="h-9 w-9 object-contain transition-transform group-hover:scale-105" />
      <span class="text-lg font-bold tracking-tight text-gray-900 dark:text-gray-100">
        Apri<span class="text-accent-500">Liyantoko</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'link-underline rounded-lg px-3 py-2 text-sm font-medium transition-all',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-accent-600 dark:text-accent-400'
                : 'text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100',
            ]}
          >
            <span class="mr-1 font-mono text-xs opacity-30">{link.icon}</span>
            {link.label}
          </a>
        </li>
      ))}
      <li class="ml-2">
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          class="flex h-9 w-9 items-center justify-center rounded-xl border border-gray-200 bg-gray-50 text-gray-500 transition-all hover:border-gray-300 hover:text-gray-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-gray-200"
        >
          <!-- Sun: shown in dark mode, click to go light -->
          <svg class="h-4 w-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <!-- Moon: shown in light mode, click to go dark -->
          <svg class="h-4 w-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
      </li>
    </ul>

    <!-- Mobile controls -->
    <div class="flex items-center gap-2 md:hidden">
      <button
        id="theme-toggle-mobile"
        aria-label="Toggle dark mode"
        class="flex h-9 w-9 items-center justify-center rounded-xl border border-gray-200 bg-gray-50 text-gray-500 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400"
      >
        <svg class="h-4 w-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="h-4 w-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        class="flex h-9 w-9 items-center justify-center rounded-xl border border-gray-200 bg-gray-50 text-gray-500 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400"
      >
        <svg id="menu-open-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-close-icon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden fixed inset-x-0 top-[65px] bottom-0 z-40 bg-white/95 backdrop-blur-xl dark:bg-gray-950/95 md:hidden">
    <ul class="flex flex-col gap-2 px-6 py-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'flex items-center gap-3 rounded-xl px-4 py-3 text-lg font-medium transition-all',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'bg-primary-50 text-accent-600 dark:bg-primary-900/20 dark:text-accent-400'
                : 'text-gray-600 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-gray-800/50',
            ]}
          >
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gray-100 font-mono text-sm text-gray-500 dark:bg-gray-800 dark:text-gray-400">{link.icon}</span>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  menuBtn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden', !isHidden);
    closeIcon?.classList.toggle('hidden', isHidden);
  });

  // Theme toggle — only the toggle action, initialization is in BaseLayout <head>
  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
</script>
